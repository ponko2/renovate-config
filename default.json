{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergePatch",
    ":disableRateLimiting",
    ":gitSignOff",
    ":semanticCommits",
    ":separatePatchReleases",
    ":timezone(Asia/Tokyo)"
  ],
  "github-actions": {
    "automerge": false,
    "packageRules": [
      {
        "matchPackageNames": ["ponko2/actions"],
        "automerge": true,
        "minimumReleaseAge": "0 days"
      }
    ]
  },
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "minimumReleaseAge": "3 days",
  "nix": {
    "enabled": true
  },
  "npm": {
    "extends": [
      "group:definitelyTyped",
      "helpers:disableTypesNodeMajor",
      "security:minimumReleaseAgeNpm",
      ":automergeTypes"
    ]
  },
  "pep621": {
    "packageRules": [
      {
        "matchDepTypes": ["requires-python"],
        "rangeStrategy": "replace"
      }
    ]
  },
  "rangeStrategy": "bump",
  "schedule": ["* 0-4 * * *"]
}
